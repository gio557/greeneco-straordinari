# Copia questo file in ".env" e inserisci le chiavi del tuo progetto Supabase.
# Le trovi in: Supabase > Project Settings > API
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=la-tua-chiave-anon-pubblica

# Anti-frode Livello 3 (cross-check posizione GPS ↔ IP). OPZIONALE e disattivato
# di default. Mettere a "true" SOLO dopo aver deployato la edge function
# `clocking-ip-check` (supabase functions deploy clocking-ip-check) e dopo
# valutazione col Consulente (controllo a distanza, art. 4 L. 300/1970 + GDPR).
VITE_IP_CHECK_ENABLED=false
